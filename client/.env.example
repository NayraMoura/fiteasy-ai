# ====================================
# FitEasy AI - Client Environment
# ====================================
# Copie este arquivo para .env e preencha com seus valores reais

# ========== SUPABASE ==========
# URL do seu projeto Supabase
# Encontre em: https://supabase.com/dashboard
# Settings > API > Project URL
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"

# Chave Pública (anon) do Supabase
# Settings > API > anon key
VITE_SUPABASE_ANON_KEY="eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..."

# ========== API BACKEND ==========
# URL base da API Express backend
# Local: http://localhost:3001
# Produção: https://seu-api-dominio.com
VITE_API_URL="http://localhost:3001"

# ====================================
# INSTRUÇÕES:
# ====================================
# 1. Copie este arquivo para .env.local (or .env.development)
# 2. Preencha cada variável com seus valores reais
# 3. NUNCA commit .env com dados sensíveis
# 4. Use .env.example para commits
# 5. Reinicie o dev server após alterar as variáveis
