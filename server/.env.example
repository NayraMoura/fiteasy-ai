# ====================================
# FitEasy AI - Backend Environment
# ====================================
# Copie este arquivo para .env e preencha com seus valores reais

# ========== DATABASE ==========
# PostgreSQL Connection String
# Formato: postgresql://usuario:senha@localhost:5432/nome_banco
DATABASE_URL="postgresql://user:password@localhost:5432/fiteasy_ai"

# ========== SUPABASE ==========
# Credenciais do projeto Supabase
# Encontre em: Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL="https://seu-projeto.supabase.co"

# Chave Pública (anon)
# Encontre em: Settings > API > anon key
SUPABASE_ANON_KEY="eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..."

# Chave Privada (service_role)
# CUIDADO: Mantenha esta chave segura!
# Encontre em: Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY="eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..."

# ========== GOOGLE GENERATIVE AI ==========
# Chave API para Google Gemini
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY="AIzaSyD1234567890abcdefg..."

# ========== SERVER ==========
# Porta onde o servidor Express rodará
PORT=3001

# Ambiente (development ou production)
NODE_ENV="development"

# ====================================
# INSTRUÇÕES:
# ====================================
# 1. Copie este arquivo para .env
# 2. Preencha cada variável com seus valores reais
# 3. NUNCA commit .env com dados sensíveis
# 4. Use .env.example para commits
